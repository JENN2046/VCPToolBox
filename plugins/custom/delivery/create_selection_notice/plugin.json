{
  "name": "create_selection_notice",
  "display_name": "摄影工作室·选片通知",
  "version": "2.0.0",
  "status": "staging",
  "category": "delivery",
  "description": "为选片阶段项目生成客户选片通知草稿。",
  "author": "PhotoStudio",
  "schema_version": "2026-04-22",
  "compatibility": {
    "vcp_min": "7.1.2",
    "vcp_max_tested": "7.1.2"
  },
  "timeout_seconds": 15,
  "retry_policy": "none",
  "idempotent": true,
  "requires_context_bridge": false,
  "input_schema": {
    "type": "object",
    "required": ["project_id"],
    "properties": {
      "project_id": { "type": "string" },
      "selection_deadline": { "type": "string" },
      "selection_method": { "type": "string" },
      "note_to_client": { "type": "string" },
      "tone": { "type": "string", "enum": ["formal", "friendly", "warm"] }
    }
  },
  "output_schema": {
    "type": "object",
    "required": ["success", "data", "error", "meta"],
    "properties": {
      "success": { "type": "boolean" },
      "data": { "type": ["object", "null"] },
      "error": { "type": ["object", "null"] },
      "meta": { "type": "object" }
    }
  },
  "config_schema": {
    "DebugMode": { "type": "boolean", "default": false },
    "PhotoStudioDataPath": { "type": "string", "default": "", "description": "摄影工作室数据根目录" }
  },
  "runtime": {
    "plugin_type": "hybridservice",
    "entry_point": {
      "script": "src/index.js"
    },
    "communication": {
      "protocol": "direct"
    }
  },
  "capabilities": {
    "invocationCommands": [
      {
        "commandIdentifier": "CreateSelectionNotice",
        "command": "create_selection_notice",
        "description": "为选片阶段项目生成客户通知草稿。",
        "example": "tool_name: create_selection_notice, project_id: proj_001, selection_deadline: 2026-05-21"
      }
    ]
  }
}
