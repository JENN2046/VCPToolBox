{
  "name": "generate_delivery_queue_schedule",
  "display_name": "Photo Studio Delivery Queue Schedule",
  "version": "2.0.0",
  "status": "staging",
  "category": "reporting",
  "description": "Builds a bounded local-shadow delivery schedule from existing queue records.",
  "author": "PhotoStudio",
  "schema_version": "2026-04-22",
  "compatibility": {
    "vcp_min": "7.1.2",
    "vcp_max_tested": "7.1.2"
  },
  "timeout_seconds": 15,
  "retry_policy": "none",
  "idempotent": true,
  "requires_context_bridge": false,
  "input_schema": {
    "type": "object",
    "properties": {
      "reference_date": { "type": "string" },
      "project_id": { "type": "string" },
      "export_key": { "type": "string" },
      "target_type": { "type": "string" },
      "delivery_state": { "type": "string" },
      "max_items": { "type": "integer" }
    }
  },
  "output_schema": {
    "type": "object",
    "required": ["success", "data", "error", "meta"],
    "properties": {
      "success": { "type": "boolean" },
      "data": { "type": ["object", "null"] },
      "error": { "type": ["object", "null"] },
      "meta": { "type": "object" }
    }
  },
  "config_schema": {
    "DebugMode": { "type": "boolean", "default": false },
    "PhotoStudioDataPath": { "type": "string", "default": "", "description": "Photo studio data root." }
  },
  "runtime": {
    "plugin_type": "hybridservice",
    "entry_point": {
      "script": "src/index.js"
    },
    "communication": {
      "protocol": "direct"
    }
  },
  "capabilities": {
    "invocationCommands": [
      {
        "commandIdentifier": "GenerateDeliveryQueueSchedule",
        "command": "generate_delivery_queue_schedule",
        "description": "Group actionable local-shadow delivery items into bounded schedule windows.",
        "example": "tool_name: generate_delivery_queue_schedule, reference_date: 2026-05-06"
      }
    ]
  }
}
