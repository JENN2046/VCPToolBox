{
  "name": "update_project_status",
  "display_name": "摄影工作室·项目状态流转",
  "version": "2.0.0",
  "status": "staging",
  "category": "project",
  "description": "按 Guide 对齐后的状态机更新项目状态，并写入 Status Log。",
  "author": "PhotoStudio",
  "schema_version": "2026-04-22",
  "compatibility": {
    "vcp_min": "7.1.2",
    "vcp_max_tested": "7.1.2"
  },
  "timeout_seconds": 15,
  "retry_policy": "none",
  "idempotent": true,
  "requires_context_bridge": false,
  "input_schema": {
    "type": "object",
    "required": [
      "project_id",
      "new_status"
    ],
    "properties": {
      "project_id": { "type": "string" },
      "new_status": {
        "type": "string",
        "enum": ["lead", "quoted", "confirmed", "preparing", "shot", "selection_pending", "retouching", "delivering", "completed", "archived", "cancelled"]
      },
      "reason": { "type": "string" },
      "changed_by": { "type": "string" }
    }
  },
  "output_schema": {
    "type": "object",
    "required": ["success", "data", "error", "meta"],
    "properties": {
      "success": { "type": "boolean" },
      "data": { "type": ["object", "null"] },
      "error": { "type": ["object", "null"] },
      "meta": { "type": "object" }
    }
  },
  "config_schema": {
    "DebugMode": { "type": "boolean", "default": false },
    "PhotoStudioDataPath": { "type": "string", "default": "", "description": "摄影工作室数据根目录" }
  },
  "runtime": {
    "plugin_type": "hybridservice",
    "entry_point": {
      "script": "src/index.js"
    },
    "communication": {
      "protocol": "direct"
    }
  },
  "capabilities": {
    "invocationCommands": [
      {
        "commandIdentifier": "UpdateProjectStatus",
        "command": "update_project_status",
        "description": "更新项目状态，支持 Guide 对齐后的状态流和 status log 记录。",
        "example": "tool_name: update_project_status, project_id: proj_001, new_status: quoted, reason: 客户确认报价"
      }
    ]
  }
}
