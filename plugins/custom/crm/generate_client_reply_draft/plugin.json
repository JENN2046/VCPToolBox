{
  "name": "generate_client_reply_draft",
  "display_name": "摄影工作室·客户沟通草稿",
  "version": "2.0.0",
  "status": "staging",
  "category": "crm",
  "description": "基于客户与项目上下文生成客户沟通草稿，输出 draft_title / draft_body。",
  "author": "PhotoStudio",
  "schema_version": "2026-04-22",
  "compatibility": {
    "vcp_min": "7.1.2",
    "vcp_max_tested": "7.1.2"
  },
  "timeout_seconds": 15,
  "retry_policy": "none",
  "idempotent": true,
  "requires_context_bridge": false,
  "input_schema": {
    "type": "object",
    "required": [
      "project_id",
      "context_type"
    ],
    "properties": {
      "project_id": { "type": "string" },
      "customer_id": { "type": "string" },
      "context_type": { "type": "string", "enum": ["quotation", "schedule", "delivery", "general"] },
      "key_points": { "type": "string" },
      "tone": { "type": "string", "enum": ["formal", "friendly", "warm"] }
    }
  },
  "output_schema": {
    "type": "object",
    "required": ["success", "data", "error", "meta"],
    "properties": {
      "success": { "type": "boolean" },
      "data": { "type": ["object", "null"] },
      "error": { "type": ["object", "null"] },
      "meta": { "type": "object" }
    }
  },
  "config_schema": {
    "DebugMode": { "type": "boolean", "default": false },
    "PhotoStudioDataPath": { "type": "string", "default": "", "description": "摄影工作室数据根目录" }
  },
  "runtime": {
    "plugin_type": "hybridservice",
    "entry_point": {
      "script": "src/index.js"
    },
    "communication": {
      "protocol": "direct"
    }
  },
  "capabilities": {
    "invocationCommands": [
      {
        "commandIdentifier": "GenerateReplyDraft",
        "command": "generate_client_reply_draft",
        "description": "为项目生成客户沟通草稿，支持 quotation / schedule / delivery / general 场景。",
        "example": "tool_name: generate_client_reply_draft, project_id: proj_001, context_type: quotation, tone: warm"
      }
    ]
  }
}
