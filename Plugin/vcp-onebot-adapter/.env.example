# VCP OneBot Adapter 配置模板
# 复制此文件为 .env 并填入实际值

# ==================== OneBot 连接配置 ====================
# OneBot WebSocket 地址，支持以下实现：
# - go-cqhttp (推荐): https://github.com/Mrs4s/go-cqhttp
# - NapCat: https://github.com/NapNeko/NapCatQQ
# - LLOneBot: https://github.com/LLOneBot/LLOneBot
# - Lagrange.OneBot: https://github.com/LagrangeDev/Lagrange.Core
ONEBOT_WS_URL=ws://127.0.0.1:3001

# OneBot 访问令牌（可选），如果 OneBot 配置了 access_token 则需填写
ONEBOT_ACCESS_TOKEN=

# ==================== VCP ChannelHub 配置 ====================
# VCP ChannelHub B2 事件入口地址
# 默认端口：6010（生产环境）或 6005（开发环境）
VCP_CHANNEL_HUB_URL=http://127.0.0.1:6010/internal/channel-hub/events

# 适配器唯一标识，需与 ChannelHub 注册的 ID 一致
VCP_ADAPTER_ID=onebot-qq-main

# 桥接密钥，与 VCP ChannelHub 配置保持一致
VCP_CHANNEL_BRIDGE_KEY=your-bridge-key-here

# ==================== Agent 配置 ====================
# 默认 Agent 名称（需与 VCP 中注册的 Agent 一致）
VCP_AGENT_NAME=Nova

# Agent 显示名称（可选，用于展示）
VCP_AGENT_DISPLAY_NAME=Nova

# ==================== 运行时配置 ====================
# 请求超时时间（毫秒），默认 120 秒
VCP_TIMEOUT_MS=120000

# 日志级别：debug, info, warn, error
LOG_LEVEL=info

# ==================== 平台能力配置（可选） ====================
# 是否支持图片消息：true/false
ONEBOT_SUPPORTS_IMAGE=true

# 是否支持文件直发：true/false（QQ 通常不支持，会转为文本链接）
ONEBOT_SUPPORTS_FILE=false

# 是否支持语音消息：true/false
ONEBOT_SUPPORTS_AUDIO=true

# 单条消息最大长度（QQ 限制约 4500 字）
ONEBOT_MAX_MESSAGE_LENGTH=4500
