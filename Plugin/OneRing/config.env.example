# OneRing is conservative by default.
# Copy this file to config.env only after the operator explicitly enables OneRing.

ONERING_ENABLED=false
ONERING_RECORD_ONLY=true
ONERING_ALLOW_CONTEXT_PATCH=false
ONERING_USER_NAME=User
ONERING_MAX_DB_RECORDS=100

# Optional explicit runtime locations.
# If omitted, OneRing reads Plugin/OneRing/OneRingConfig.json and writes enabled
# local stores under Plugin/OneRing/data/.
# ONERING_HOT_CONFIG_PATH=
# ONERING_DATA_DIR=
