# WeeklyReportGenerator config
VCP_API_URL=http://127.0.0.1:6005
VCP_API_KEY=your_vcp_api_key
DEFAULT_MODEL=Nova

# DingTalk AI table export
DINGTALK_TABLE_UUID=your_table_uuid_here
DINGTALK_BASE_ID=your_base_id_here
DINGTALK_TABLE_ID=your_table_id_here
DINGTALK_WEEKLY_TABLE_WRITE_TOOL=record create

# Optional: keep consistent with DingTalkCLI gray policy
# query_only / low_risk_write / full_write
DWS_GRAY_STAGE=full_write
